# Copy this to .env and fill in your values

# JWT secret — change this to a long random string in production
JWT_SECRET=report-defence-change-this-secret

# Code required to register as an operator (keep this private)
OPERATOR_CODE=RD-OPERATOR-2024

# File storage paths (defaults to /tmp — use persistent storage in production)
UPLOAD_DIR=/tmp/rd_uploads
LETTERS_DIR=/tmp/rd_letters
DB_FILE=/tmp/rd_db.json

# CORS — set to your Lovable frontend URL in production
# CORS_ORIGIN=https://your-lovable-app.lovable.app
